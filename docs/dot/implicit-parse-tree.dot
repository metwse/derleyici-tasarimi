graph implicit_parse_tree {
    ranksep = 0.5;
    rankdir = LR;

    node [shape = "plaintext"];

    eval_print [label = "eval_print()"];
    match_semi [label = ";"];
    eval_expr1 [label = "eval_expr()"];
    match_print [label = "print"];

    eval_expr2 [label = "eval_expr()"]
    match_minus1 [label = "-"]

    eval_term1 [label = "eval_term()"]
    eval_factor1 [label = "eval_factor()"]
    eval_atom1 [label = "eval_atom()"]
    match_int1 [label = "10"]

    eval_expr3 [label = "eval_expr()"]
    match_minus2 [label = "-"]

    eval_term2 [label = "eval_term()"]
    eval_factor2 [label = "eval_factor()"]
    eval_atom2 [label = "eval_atom()"]
    match_int2 [label = "2"]

    eval_term3 [label = "eval_term()"]
    eval_factor3 [label = "eval_factor()"]
    eval_atom3 [label = "eval_atom()"]
    match_int3 [label = "3"]

    eval_print -- { match_print, eval_expr1, match_semi };

    eval_expr1 -- { eval_term1, match_minus1, eval_expr2 };
    eval_term1 -- eval_factor1 -- eval_atom1 -- match_int1;

    eval_expr2 -- { eval_term2, match_minus2, eval_expr3 };
    eval_term2 -- eval_factor2 -- eval_atom2 -- match_int2;

    eval_expr3 -- eval_term3;
    eval_term3 -- eval_factor3 -- eval_atom3 -- match_int3;
}
