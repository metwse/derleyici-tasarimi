graph implicit_parse_tree_simplified {
    ranksep = 0.5;
    rankdir = LR;

    node [shape = "plaintext"];

    edge [labeldistance = 2, labelangle = 0, fontsize = 10];

    eval_print [label = "eval_print()"];
    match_semi [label = ";"];
    eval_expr1 [label = "eval_expr()"];
    match_print [label = "print"];

    eval_expr2 [label = "eval_expr()"]
    match_minus1 [label = "-"]

    match_int1 [label = "10"]

    eval_expr3 [label = "eval_expr()"]
    match_minus2 [label = "-"]

    match_int2 [label = "2"]

    match_int3 [label = "3"]

    eval_print -- { match_print, eval_expr1, match_semi };

    eval_expr1 -- match_int1 [label = "T/F/A"];
    eval_expr1 -- { match_minus1, eval_expr2 };

    eval_expr2 -- match_int2 [label = "T/F/A"];
    eval_expr2 -- { match_minus2, eval_expr3 };

    eval_expr3 -- match_int3 [label = "T/F/A"];
}
